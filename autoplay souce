local function startmovement(mode)
    patrolmode = mode
    currentwaypoint = 1
    local btn = (mode == "right") and rightbtn or leftbtn
    btn.Text = "stop " .. mode
end

rightbtn.MouseButton1Click:Connect(function()
    if patrolmode == "right" then patrolmode = "none" rightbtn.Text = "auto play right"
    else startmovement("right") end
end)

leftbtn.MouseButton1Click:Connect(function()
    if patrolmode == "left" then patrolmode = "none" leftbtn.Text = "auto play left"
    else startmovement("left") end
end)

RunService.Heartbeat:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or patrolmode == "none" then return end
    
    local wps = patrolmode == "right" and rightwaypoints or leftwaypoints
    local targetpos = wps[currentwaypoint]
    local diff = (Vector3.new(targetpos.X, 0, targetpos.Z) - Vector3.new(root.Position.X, 0, root.Position.Z))
    
    if diff.Magnitude > 3 then
        local speed = (currentwaypoint >= 3) and stealspeedvalue or walkspeedvalue
        root.AssemblyLinearVelocity = Vector3.new(diff.Unit.X * speed, root.AssemblyLinearVelocity.Y, diff.Unit.Z * speed)
    else
        if currentwaypoint == #wps then
            patrolmode = "none"
            rightbtn.Text = "auto play right"
            leftbtn.Text = "auto play left"
        else
            currentwaypoint = currentwaypoint + 1
        end
    end
end)


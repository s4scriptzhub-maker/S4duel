-- Special function for creating buttons INSIDE the tab ScrollingFrames
local function CreateHubButton(parent, text, stateKey, hasGear, callback)
    local BtnContainer = Instance.new("Frame", parent)
    BtnContainer.BackgroundTransparency = 1

    local Btn = Instance.new("TextButton", BtnContainer)
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundColor3 = Theme.Background
    Btn.BackgroundTransparency = Theme.GlassTransparency
    Btn.Text = ""
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 4)
    
    -- In-Tab Border Glow (Global Inactive Purple until clicked)
    local stroke = Instance.new("UIStroke", Btn)
    local _, updateShine = ApplyPlasmaBorder(Btn, true)

    local Label = Instance.new("TextLabel", Btn)
    Label.Size = UDim2.new(1, -20, 1, 0)
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Theme.TextWhite
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Center

    if hasGear then
        local GearBtn = Instance.new("TextButton", Btn)
        GearBtn.Size = UDim2.new(0, 20, 0, 20)
        GearBtn.Position = UDim2.new(1, -22, 1, -22)
        GearBtn.BackgroundColor3 = Theme.PanelBg
        GearBtn.BackgroundTransparency = 1
        GearBtn.Text = "⚙️"
        GearBtn.TextSize = 12
        GearBtn.ZIndex = 5
        -- [placeholder for settings menu toggling logics]
    end

    if stateKey then
        -- Feature Button Visual Toggle (ACTIVE NAVIGATION LOGIC ONLY)
        Btn.Activated:Connect(function()
            -- [placeholder for hub settings/navigation special logics]
            
            -- Actual toggle placeholder
            local newState = not States[stateKey]
            States[stateKey] = newState -- Visual state only
            
            -- Special Logic: duelfucker active toggle
            if stateKey == "DuelFuckerMode" and newState then
                MainWindow.Visible = false
                ToggleHubBtn.Visible = false
                QuickAccessHub.Visible = true
            end

            if callback then callback(newState) end

            -- Sync visuals across menus
            if UIRegistry[stateKey] then
                for _, func in pairs(UIRegistry[stateKey]) do func(newState) end
            end
        end)

        -- Visual Sync Registry
        if not UIRegistry[stateKey] then UIRegistry[stateKey] = {} end
        table.insert(UIRegistry[stateKey], function(state)
            if state then
                TweenService:Create(Btn, TweenFast, {BackgroundColor3 = Theme.PanelBg, BackgroundTransparency = 0.3}):Play()
                updateShine(Theme.AccentFill) -- Fill becomes active magenta
            else
                TweenService:Create(Btn, TweenFast, {BackgroundColor3 = Theme.Background, BackgroundTransparency = Theme.GlassTransparency}):Play()
                updateShine(Theme.InactiveBorder) -- Back to dim purple
            end
        end)
    else
        -- Taunt/Rejoin Button (One-Off Trigger) Visual feedback only
        Btn.Activated:Connect(function()
            task.spawn(function()
                TweenService:Create(Btn, TweenFast, {BackgroundColor3 = Theme.PanelBg, BackgroundTransparency = 0.3}):Play()
                updateShine(Theme.AccentFill)
                task.wait(0.15)
                TweenService:Create(Btn, TweenFast, {BackgroundColor3 = Theme.Background, BackgroundTransparency = Theme.GlassTransparency}):Play()
                updateShine(Theme.InactiveBorder)
            end)
            if callback then callback() end
        end)
    end
end


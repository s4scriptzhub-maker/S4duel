local function CreateTab(tabName, xPositionScale)
    local TabBtn = Instance.new("TextButton", TabContainer)
    TabBtn.Size = UDim2.new(0.5, 0, 1, 0)
    TabBtn.Position = UDim2.new(xPositionScale, 0, 0, 0)

-- Special function to build the floating, glowing-plasma-purple feature buttons
local function CreateFloatingButton(text, stateKey, defaultPos)
    local frame = Instance.new("Frame", QuickAccessHub)
    frame.Size = UDim2.new(0, 140, 0, 42)
    frame.Position = defaultPos
    frame.BackgroundColor3 = Theme.Background
    frame.BackgroundTransparency = Theme.GlassTransparency -- Glass effect
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    
    -- Functionality Glow Outline (Active = Purple Neon)
    local stroke = Instance.new("UIStroke", frame)
    local _, updateShine = ApplyPlasmaBorder(frame, true)

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = text
    btn.TextColor3 = Theme.TextWhite
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12

    local function HandleFloatingClick()
        -- [placeholder for floating quick access click logic updates]
        -- Handle visual feedback
        local newState = not States[stateKey] -- Visually toggle visual state
        States[stateKey] = newState 
        
        -- Special Logic: Lock GUI specific visual shift (Plasma -> Danger Red)
        if stateKey == "LockGUI" then
            guiLocked = not guiLocked
            btn.Text = guiLocked and "LOCKED" or "LOCK GUI"
            updateShine(guiLocked and Theme.Danger or Theme.BorderNeon)
            return
        end

        -- Sync across menus visually
        if UIRegistry[stateKey] then
            for _, func in pairs(UIRegistry[stateKey]) do func(newState) end
        end
    end

    MakeFloatingDraggable(frame, btn, HandleFloatingClick)

    -- Register sync visuals function
    if not UIRegistry[stateKey] then UIRegistry[stateKey] = {} end
    table.insert(UIRegistry[stateKey], function(state)
        if state then
            TweenService:Create(btn, TweenFast, {TextColor3 = Theme.Success}):Play()
            TweenService:Create(frame, TweenFast, {BackgroundColor3 = Theme.PanelBg, BackgroundTransparency = 0.3}):Play()
            updateShine(Theme.AccentFill)
        else
            TweenService:Create(btn, TweenFast, {TextColor3 = Theme.TextWhite}):Play()
            TweenService:Create(frame, TweenFast, {BackgroundColor3 = Theme.Background, BackgroundTransparency = Theme.GlassTransparency}):Play()
            updateShine(Theme.InactiveBorder)
        end
    end)
end

